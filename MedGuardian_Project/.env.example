# Copy this file to .env and fill in your values before running the app.
# Never commit .env to version control.

# Absolute path where the SQLite database file should be stored.
# Defaults to medguardian.db in the project root.
MEDGUARDIAN_DB_PATH=/path/to/your/medguardian.db

# Login credentials for the app.
# Generate a new password hash with: python -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9

# Set to "true" to enable verbose debug logging.
DEBUG=false
